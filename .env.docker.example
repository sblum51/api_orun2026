# Copy to .env.docker (or .env.preprod / .env.prod) and customize.
# This file is read by `docker compose --env-file .env.docker up`.

# Symfony
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-me-with-a-long-random-string

# Database
POSTGRES_VERSION=16
POSTGRES_DB=orun
POSTGRES_USER=orun
POSTGRES_PASSWORD=replace-me

# JWT (passphrase used to encrypt the private key)
JWT_PASSPHRASE=replace-me

# Caddy / FrankenPHP
SERVER_NAME=:80
HTTP_PORT=8080
HTTPS_PORT=8443

# CORS (allowed origins regex)
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
